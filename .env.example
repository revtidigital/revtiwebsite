# ==========================================
# Revti CMS — Environment Variables
# Copy to .env and fill in real values.
# On Vercel, set these in Project → Settings → Environment Variables.
# ==========================================

# --- Database (PostgreSQL: Neon / Supabase / Vercel Postgres) ---
# Pooled connection string used by the app at runtime (serverless-safe).
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
# Direct (non-pooled) connection, used by Prisma migrations.
DIRECT_DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth.js / NextAuth v5 ---
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-strong-random-secret"
# Canonical app URL. Vercel sets this automatically in production; required locally.
AUTH_URL="http://localhost:3000"

# --- Vercel Blob Storage (media uploads) ---
# Create a Blob store in the Vercel dashboard; token is provisioned automatically
# on Vercel. Needed locally for uploads to work.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxx"

# --- Public app URL (used by metadataBase / SEO / absolute links) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
